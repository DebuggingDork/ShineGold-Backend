# --- Supabase Postgres ---
# Region and pooler prefix from Supabase dashboard → Project Settings → Database
SUPABASE_DB_REGION=ap-south-1
SUPABASE_POOLER_PREFIX=aws-1

# Transaction pooler (port 6543) for app runtime — URL-encode special chars in password
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres

# Direct connection for Alembic (auto-rewritten to session pooler port 5432 when needed)
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:[URL-ENCODED-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=shinegold-media

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development

# Max distance (km) from executive home location to farm for proximity assignment
EXECUTIVE_ASSIGNMENT_RADIUS_KM=70

# --- Supabase Postgres ---
# Region and pooler prefix from Supabase dashboard → Project Settings → Database
SUPABASE_DB_REGION=ap-south-1
SUPABASE_POOLER_PREFIX=aws-1

# Transaction pooler (port 6543) for app runtime — URL-encode special chars in password
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Direct connection for Alembic (session pooler port 5432)
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=shinegold-media

# --- JWT ---
JWT_SECRET_KEY=generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
# Use "production" on Render / live servers
ENVIRONMENT=development

# Optional comma-separated CORS origins (leave empty to allow all)
# CORS_ORIGINS=https://your-admin-site.example.com

# Max distance (km) from executive home location to farm for proximity assignment
EXECUTIVE_ASSIGNMENT_RADIUS_KM=70

# Days after a completed visit before the farm is due for another visit
FARM_VISIT_COOLDOWN_DAYS=30

# Voice notes auto-stop / reject above this length (seconds)
MAX_VOICE_NOTE_SECONDS=150
MAX_VOICE_UPLOAD_BYTES=8388608

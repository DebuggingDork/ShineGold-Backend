# --- Supabase Postgres ---
# Use the "Connection pooling" (pgbouncer, port 6543) URI for app runtime
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres

# Use the direct (non-pooled, port 5432) URI for Alembic migrations
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=shinegold-media

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development
